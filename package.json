{
  "name": "codefox",
  "version": "0.1.0",
  "private": true,
  "description": "CodeFox: Telegram control plane for Codex",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "local:cli": "tsx src/local-cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "npm run build && npm test"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
