{
  "name": "codefox",
  "version": "0.1.0",
  "private": true,
  "description": "CodeFox: Telegram control plane for Codex",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "dev:stop": "tsx src/stop-cli.ts",
    "ui": "tsx src/ui.ts",
    "handoff:cli": "tsx src/handoff-cli.ts",
    "demo:handoff": "tsx scripts/demo-handoff-cli.ts",
    "demo:handoff-lifecycle": "tsx scripts/demo-handoff.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "npm run build && npm test"
  },
  "dependencies": {
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/qrcode": "^1.5.6",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
