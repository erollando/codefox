# Required
TELEGRAM_BOT_TOKEN=123456789:replace_me

# Optional: override default config path
CODEFOX_CONFIG=./config/codefox.config.json

# Optional: set to 1 to mirror audit events to stdout
CODEFOX_AUDIT_STDOUT=0

# Optional: relay bearer token (used only when externalRelay.authTokenEnvVar is configured)
CODEFOX_EXTERNAL_RELAY_TOKEN=replace_me_if_external_relay_auth_enabled
